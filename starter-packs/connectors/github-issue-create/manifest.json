{
  "name": "GitHub Issue Create",
  "type": "github_issue_create",
  "runtime": "process",
  "entry": "python3 main.py",
  "inputs": [
    "repository",
    "title",
    "body",
    "labels",
    "assignees",
    "milestone"
  ],
  "outputs": [
    "issue_created",
    "mock",
    "issue_number",
    "issue_url",
    "issue_id"
  ],
  "limits": {
    "timeout_ms": 30000
  },
  "version": "0.1.0"
}
