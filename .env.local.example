OPENAI_API_KEY=YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4.1-mini

ACSA_DEMO_EMAIL_TO=you@example.com
ACSA_SMTP_HOST=smtp.example.com
ACSA_SMTP_PORT=587
ACSA_SMTP_USERNAME=you@example.com
ACSA_SMTP_PASSWORD=your-app-password
ACSA_SMTP_FROM=you@example.com
ACSA_SMTP_TLS=auto
ACSA_SMTP_TIMEOUT_SECS=25

# --- Startup Opportunity Pipeline ---
FIRECRAWL_API_KEY=your-firecrawl-api-key
# Base64-encode your service account JSON:  base64 -i your-sa-key.json | tr -d '\n'
GOOGLE_SHEETS_CREDENTIALS_JSON=paste-base64-encoded-string-here
# Or use an absolute file path instead:
# GOOGLE_SHEETS_CREDENTIALS_PATH=/Users/you/path/to/google-sheets-sa.json
CRUSTDATA_API_KEY=
